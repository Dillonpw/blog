<button
  type="button"
  class="flex h-9 w-9 items-center justify-center hover:rounded-xl hover:bg-gray-600 hover:text-white dark:hover:text-zinc-950 dark:hover:bg-gray-200"
  id="theme-selector"
>
  <span class="sr-only"
    >Enable <span class="dark:hidden">light</span><span
      class="hidden dark:inline">dark</span
    > mode</span
  >
  <i class="fa-solid fa-sun hidden text-3xl dark:inline"></i>

  <i class="fa-solid fa-moon text-3xl dark:hidden"></i>
</button>
<script>
  document.getElementById("theme-selector")?.addEventListener("click", () => {
    if (localStorage.theme === "dark") {
      localStorage.theme = "light";
      document.documentElement.classList.remove("dark");
    } else {
      localStorage.theme = "dark";
      document.documentElement.classList.add("dark");
    }
  });
</script>
